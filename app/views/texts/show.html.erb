<% if notice %>
  <p id="notice" class="alert">
<%= notice %>
  </p>
<% end %>
<h4 style="color:#456789">This is <%= @text.user.name if @text.user %>'s square.</h4>
<br>

  <ol style="width:<%= @text.rows.first.length * 50 +26%>px; margin: 0 auto;">
    <% @text.rows.each do |row| %>
      <li>
        <ol>
          <% row.each do |square| %>
            <li class="square" style='background-color:#<%= square.color %>'></li>
          <% end %>
        </ol>
      </li> 
    <% end %>
  </ol>

<br>
<br>
<br>
<br>
  
<p>
  <b>YOUR TEXT:</b>
  <%= @text.input %>
<br>
<form action="select.htm">
  <p>Please choose if the text should be published or not:</p>
    <select name="Show/Hide" size="2">
      <option>Show Text</option>
      <option>Hide Text</option>
    </select>

</p>
  
<br>
<br>
<br>

<%= link_to 'Edit', edit_text_path(@text) %> |
<%= link_to 'Listing Texts', texts_path %> |
<%= link_to 'New Text', new_text_path %> |

